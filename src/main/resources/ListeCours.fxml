<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.ListeCours"
            stylesheets="@app.css"
            prefWidth="1050.0" prefHeight="650.0">

    <left>
        <VBox prefWidth="230.0" styleClass="sidebar">
            <Label text="DINARI" styleClass="brand"/>
            <Label text="FINTECH MANAGEMENT" styleClass="brand-sub"/>

            <Separator opacity="0.2"/>

            <Button text="🏠 Accueil" styleClass="nav-btn" onAction="#goHome"/>

            <Button text="📚 Modules Formation"
                    styleClass="nav-btn nav-btn-active"
                    onAction="#goListeCours"/>

            <Button text="📝 Quiz"
                    styleClass="nav-btn"
                    onAction="#goListeQuiz"/>
            
            <Button text="⭐ Ajouter Avis" styleClass="nav-btn" onAction="#goAjouterAvis"/>
            <Button text="⭐ Liste Avis" styleClass="nav-btn" onAction="#goListeAvis"/>

            <Button text="➕ Nouveau Module"
                    styleClass="nav-btn"
                    onAction="#goAjouterCours"/>

            <Button text="➕ Nouveau Quiz"
                    styleClass="nav-btn"
                    onAction="#goAjouterQuiz"/>

            <Button text="💰 Dépenses" styleClass="nav-btn"/>
            <Button text="⭐ Abonnement" styleClass="nav-btn"/>
            <Button text="📊 Budget" styleClass="nav-btn"/>

            <Pane VBox.vgrow="ALWAYS"/>

            <Label text="Administrateur" styleClass="sidebar-footer"/>
            <Label text="admin@dinari.com" styleClass="sidebar-footer"/>
        </VBox>
    </left>

    <center>
        <VBox styleClass="content">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Modules de Formation Financière" styleClass="page-title"/>
                <Pane HBox.hgrow="ALWAYS"/>
                <Button text="🔄 Rafraîchir" styleClass="ghost-btn" onAction="#refresh"/>
            </HBox>

            <HBox styleClass="toolbar" alignment="CENTER_LEFT">
                <TextField fx:id="tfSearch" promptText="Rechercher un module..." styleClass="input" HBox.hgrow="ALWAYS"/>
                <Button text="Rechercher" styleClass="primary-btn" onAction="#apply"/>
                <Button text="Réinitialiser" styleClass="ghost-btn" onAction="#reset"/>
            </HBox>

            <ListView fx:id="listViewCours" VBox.vgrow="ALWAYS"/>

        </VBox>
    </center>

</BorderPane>
