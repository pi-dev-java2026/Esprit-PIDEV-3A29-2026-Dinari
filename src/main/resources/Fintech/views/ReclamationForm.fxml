<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane styleClass="login-container" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Fintech.controllers.ReclamationFormController">
   <children>
      <VBox alignment="TOP_CENTER" maxWidth="700.0" spacing="20.0" styleClass="card" StackPane.alignment="CENTER">
         <children>
            <!-- Header Section -->
            <HBox alignment="CENTER_LEFT" spacing="15.0">
               <children>
                  <VBox>
                     <Label fx:id="formTitleLabel" styleClass="page-title" text="Créer une Réclamation" />
                     <Label styleClass="page-subtitle" text="Soumettez votre réclamation en remplissant les informations ci-dessous" />
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <HBox alignment="CENTER" spacing="5" styleClass="logo-container">
                     <Label styleClass="logo-text-id" text="ID" style="-fx-font-size: 24px;"/>
                     <Label styleClass="logo-text-dinari" text="INARI" style="-fx-font-size: 24px;"/>
                  </HBox>
               </children>
               <VBox.margin><Insets bottom="10.0" /></VBox.margin>
            </HBox>
            
            <Separator />

            <!-- Form Grid -->
            <GridPane hgap="30.0" vgap="25.0">
               <columnConstraints>
                  <ColumnConstraints percentWidth="50.0" />
                  <ColumnConstraints percentWidth="50.0" />
               </columnConstraints>
               <children>
                  <!-- Email Field -->
                  <VBox alignment="CENTER_LEFT" spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                     <children>
                        <Label styleClass="field-label" text="Adresse Email" />
                        <HBox alignment="CENTER_LEFT" styleClass="input-box">
                            <Label styleClass="input-icon" text="✉" />
                            <TextField fx:id="emailField" promptText="nom@exemple.com" styleClass="input-field-inner" HBox.hgrow="ALWAYS" />
                        </HBox>
                     </children>
                  </VBox>
                  
                  <!-- Subject Field -->
                  <VBox alignment="CENTER_LEFT" spacing="6.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                     <children>
                        <Label styleClass="field-label" text="Sujet" />
                        <HBox alignment="CENTER_LEFT" styleClass="input-box">
                            <Label styleClass="input-icon" text="📋" />
                            <TextField fx:id="subjectField" promptText="Entrez le sujet de la réclamation" styleClass="input-field-inner" HBox.hgrow="ALWAYS" />
                        </HBox>
                     </children>
                  </VBox>
                  
                  <!-- Description Field -->
                  <VBox alignment="CENTER_LEFT" spacing="6.0" GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                     <children>
                        <Label styleClass="field-label" text="Description Détaillée" />
                        <VBox styleClass="input-box" alignment="TOP_LEFT">
                           <children>
                              <HBox alignment="TOP_LEFT" spacing="5.0">
                                 <children>
                                    <Label styleClass="input-icon" text="📝" />
                                    <TextArea fx:id="descriptionField" promptText="Décrivez votre réclamation en détail..." styleClass="input-field-inner" wrapText="true" prefRowCount="8" HBox.hgrow="ALWAYS" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </children>
            </GridPane>

            <!-- Statut Field (visible for admin in edit mode only) -->
            <VBox fx:id="statutSection" alignment="CENTER_LEFT" spacing="6.0" managed="false" visible="false">
               <children>
                  <Label styleClass="field-label" text="État de la réclamation" />
                  <HBox alignment="CENTER_LEFT" styleClass="input-box">
                      <Label styleClass="input-icon" text="⚙" />
                      <ComboBox fx:id="statutComboBox" promptText="Sélectionner l'état..." styleClass="input-field-inner" maxWidth="Infinity" HBox.hgrow="ALWAYS" />
                  </HBox>
               </children>
            </VBox>

            <Separator>
               <VBox.margin><Insets top="15.0" bottom="5.0" /></VBox.margin>
            </Separator>
            
            <!-- Action Buttons Footer -->
            <HBox alignment="CENTER_RIGHT" spacing="15.0">
               <children>
                  <Button fx:id="clearButton" mnemonicParsing="false" onAction="#handleClear" prefWidth="120.0" styleClass="btn-outline" text="Effacer" />
                  <Region HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleBack" prefWidth="120.0" styleClass="btn-outline" text="Retour" />
                  <Button fx:id="submitButton" mnemonicParsing="false" onAction="#handleSubmit" prefWidth="140.0" styleClass="btn-primary" text="Soumettre" />
               </children>
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </HBox>
         </children>
         <StackPane.margin>
             <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
         </StackPane.margin>
      </VBox>
   </children>
</StackPane>
