<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.image.ImageView?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" styleClass="dashboard-root" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Fintech.controllers.UserProfileController">
   
   <!-- Sidebar -->
   <left>
      <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>
            <!-- Logo -->
            <VBox styleClass="sidebar-logo-container">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Label styleClass="logo-text" text="DINARI" />
                     </children>
                  </HBox>
                  <Label styleClass="logo-subtitle" text="Gestion Financière" />
               </children>
               <padding><Insets bottom="20.0" left="22.0" right="22.0" top="28.0" /></padding>
            </VBox>

            <!-- Divider -->
            <Separator styleClass="sidebar-divider-top">
               <VBox.margin><Insets left="20.0" right="20.0" top="10.0" bottom="20.0"/></VBox.margin>
            </Separator>

            <!-- Menu Items -->
            <VBox spacing="4.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleDashboard" styleClass="sidebar-menu-item" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="Abonnements"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

                  <Button mnemonicParsing="false" onAction="#handleTransactions" styleClass="sidebar-menu-item" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="Éducative"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

                  <Button mnemonicParsing="false" onAction="#handleBudgets" styleClass="sidebar-menu-item" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="Dépenses"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

                  <Button mnemonicParsing="false" onAction="#handleDashboard" styleClass="sidebar-menu-item" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="🏠  Tableau de bord"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

                  <Button mnemonicParsing="false" onAction="#handleDashboard" styleClass="sidebar-menu-item" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="🏠  Tableau de bord"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

                  <Button mnemonicParsing="false" styleClass="sidebar-menu-item, sidebar-menu-item-active" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="👤  Mon Profil"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="20.0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

                  <Button mnemonicParsing="false" onAction="#handleReclamations" styleClass="sidebar-menu-item" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="Réclamation"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

               </children>
            </VBox>

            <!-- Divider -->
            <Separator styleClass="sidebar-divider-bottom">
               <VBox.margin><Insets left="20.0" right="20.0" bottom="20.0"/></VBox.margin>
            </Separator>

            <!-- User Info & Logout -->
            <VBox styleClass="sidebar-user-container" spacing="15.0">
               <padding><Insets bottom="30.0" left="22.0" right="22.0" top="10.0" /></padding>
               <children>
                  <VBox spacing="2.0">
                     <children>
                        <Label styleClass="sidebar-user-label" text="Utilisateur" />
                        <Label fx:id="sidebarEmailLabel" styleClass="sidebar-user-email" text="admin@dinari.tn" />
                     </children>
                  </VBox>
                  <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-menu-item, logout-btn" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="⎋" styleClass="nav-icon" style="-fx-text-fill: #EF4444;"/>
                           <Label text="Déconnexion" style="-fx-text-fill: #EF4444;"/>
                        </HBox>
                     </graphic>
                     <padding><Insets top="8" bottom="8" left="0" right="0"/></padding>
                  </Button>
               </children>
            </VBox>

         </children>
      </VBox>
   </left>
   
   <!-- Main Content -->
   <center>
      <VBox styleClass="main-content" BorderPane.alignment="CENTER">
         <children>
            <!-- Header -->
            <HBox alignment="CENTER_LEFT" styleClass="content-header">
               <children>
                  <VBox HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="page-title" text="Profil Utilisateur" />
                        <Label styleClass="page-subtitle" text="Détails complets de l'utilisateur sélectionné." />
                     </children>
                  </VBox>
                  
                  <!-- User Profile -->
                  <HBox alignment="CENTER" spacing="10.0" styleClass="user-profile">
                     <children>
                        <VBox alignment="CENTER_RIGHT">
                           <children>
                              <Label fx:id="profileNameLabel" styleClass="profile-name" text="" minWidth="-Infinity" />
                              <Label fx:id="profileRoleLabel" styleClass="profile-role" text="" minWidth="-Infinity" />
                           </children>
                        </VBox>
                        <!-- Top-right avatar (ImageView or initial Label depending if custom photo exists) -->
                        <Label fx:id="profileAvatarLabel" styleClass="header-avatar" text="?" managed="false" visible="false" />
                        <ImageView fx:id="topRightAvatar" fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true" styleClass="profile-avatar" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
               </padding>
            </HBox>
            
            <!-- Back Button -->
            <HBox alignment="CENTER_LEFT" styleClass="table-header-section">
               <children>
                  <Button fx:id="backButton" mnemonicParsing="false" onAction="#handleBack" styleClass="add-user-btn" text="← Retour à la liste">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="15.0" left="30.0" right="30.0" top="15.0" />
               </padding>
            </HBox>
            
            <!-- User Details Card (Split Layout) -->
            <HBox styleClass="card" VBox.vgrow="ALWAYS" maxWidth="1000.0" alignment="TOP_LEFT" spacing="40.0">
               <VBox.margin>
                  <Insets bottom="30.0" left="30.0" right="30.0" />
               </VBox.margin>
               
               <children>
                  <!-- LEFT COLUMN: Avatar and Main Info -->
                  <VBox alignment="TOP_CENTER" spacing="15.0" prefWidth="250.0">
                     <children>
                        <!-- Main Avatar Image -->
                        <ImageView fx:id="userAvatarImage" fitHeight="160.0" fitWidth="160.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);" />
                        
                        <Label fx:id="userNameLabel" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: -fx-text-main;" text="Nom Utilisateur" wrapText="true" textAlignment="CENTER" />
                        
                        <Label fx:id="userRoleBadge" styleClass="role-badge" style="-fx-font-size: 13px; -fx-padding: 6 18;" text="Role" />

                        <Separator styleClass="sidebar-divider">
                           <VBox.margin><Insets top="15.0" bottom="15.0"/></VBox.margin>
                        </Separator>
                        
                        <!-- Quick Action Buttons -->
                        <VBox spacing="10.0" maxWidth="Infinity">
                           <children>
                              <Button fx:id="editButton" mnemonicParsing="false" onAction="#handleEdit" styleClass="btn-outline" text="✏️  Modifier l'utilisateur" maxWidth="Infinity"/>
                              <Button fx:id="deleteButton" mnemonicParsing="false" onAction="#handleDelete" styleClass="btn-outline" style="-fx-text-fill: #EF4444; -fx-border-color: #FECACA;" text="🗑️  Supprimer" maxWidth="Infinity"/>
                           </children>
                        </VBox>
                     </children>
                     <padding><Insets right="20.0"/></padding>
                  </VBox>
                  
                  <!-- RIGHT COLUMN: Detailed Information -->
                  <VBox spacing="20.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label styleClass="section-title" text="Informations Personnelles" />
                        
                        <!-- User Information Grid -->
                        <GridPane hgap="40.0" vgap="25.0" alignment="TOP_LEFT">
                           <columnConstraints>
                              <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="150.0" />
                              <ColumnConstraints hgrow="ALWAYS" minWidth="250.0" />
                           </columnConstraints>
                           
                           <!-- Name -->
                           <Label styleClass="field-label" text="Nom complet:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                           <Label fx:id="userNameDetailLabel" styleClass="normal-text" style="-fx-font-weight: 600; -fx-text-fill: -fx-text-main;" text="Nom Utilisateur" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                           
                           <!-- Email -->
                           <Label styleClass="field-label" text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                           <Label fx:id="userEmailLabel" styleClass="normal-text" style="-fx-font-weight: 600; -fx-text-fill: -fx-text-main;" text="email@example.com" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                           
                           <!-- Phone -->
                           <Label styleClass="field-label" text="Téléphone:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                           <Label fx:id="userPhoneLabel" styleClass="normal-text" style="-fx-font-weight: 600; -fx-text-fill: -fx-text-main;" text="+216 12 345 678" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                           
                           <!-- Password -->
                           <Label styleClass="field-label" text="Mot de passe:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                           <Label fx:id="userPasswordLabel" styleClass="normal-text" text="🔒 • • • • • • • •" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                           
                           <!-- Role -->
                           <Label styleClass="field-label" text="Rôle système:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                           <Label fx:id="userRoleLabel" styleClass="normal-text" style="-fx-font-weight: 600; -fx-text-fill: -fx-text-main;" text="User" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                        </GridPane>

                        <Separator>
                           <VBox.margin><Insets top="20.0" bottom="20.0"/></VBox.margin>
                        </Separator>

                        <Label styleClass="section-title" text="Activité Récente" />
                        
                        <VBox spacing="10.0">
                             <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <Label text="🔹" style="-fx-text-fill: -fx-primary-color;"/>
                                 <Label text="Dernière connexion enregistrée" styleClass="normal-text"/>
                                 <Region HBox.hgrow="ALWAYS" />
                                 <Label text="Aujourd'hui, 10:45" styleClass="normal-text" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;"/>
                             </HBox>
                             <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <Label text="🔹" style="-fx-text-fill: -fx-primary-color;"/>
                                 <Label text="Profil mis à jour" styleClass="normal-text"/>
                                 <Region HBox.hgrow="ALWAYS" />
                                 <Label text="Hier, 14:20" styleClass="normal-text" style="-fx-text-fill: -fx-text-muted; -fx-font-size: 12px;"/>
                             </HBox>
                        </VBox>

                     </children>
                  </VBox>
                  
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
