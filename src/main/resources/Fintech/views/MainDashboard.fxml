<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Fintech.controllers.MainDashboardController"
            prefHeight="800.0" prefWidth="1200.0" styleClass="dashboard-root" stylesheets="@../styles/styles.css">

    <!-- ═══════════ SIDEBAR ═══════════ -->
    <left>
        <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
            <children>

                <!-- Logo -->
                <VBox styleClass="sidebar-logo-container">
                   <children>
                      <HBox alignment="CENTER_LEFT" spacing="12.0">
                         <children>
                            <Label styleClass="logo-text" text="DINARI" />
                         </children>
                      </HBox>
                      <Label styleClass="logo-subtitle" text="Gestion Financière" />
                   </children>
                   <padding><javafx.geometry.Insets bottom="20.0" left="22.0" right="22.0" top="28.0" /></padding>
                </VBox>

                <!-- Divider -->
                <Separator styleClass="sidebar-divider-top">
                   <VBox.margin><javafx.geometry.Insets left="20.0" right="20.0" top="10.0" bottom="20.0"/></VBox.margin>
                </Separator>

                <!-- Menu Items -->
                <VBox spacing="4.0" VBox.vgrow="ALWAYS">
                    <children>
                        <Button mnemonicParsing="false" onAction="#showDashboard" styleClass="sidebar-menu-item" maxWidth="Infinity">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                   <Label text="Abonnements"/>
                                </HBox>
                            </graphic>
                            <VBox.margin><javafx.geometry.Insets left="0" right="0"/></VBox.margin>
                            <padding><javafx.geometry.Insets top="12" bottom="12" left="22" right="22"/></padding>
                        </Button>

                        <Button mnemonicParsing="false" styleClass="sidebar-menu-item" maxWidth="Infinity">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                   <Label text="Éducative"/>
                                </HBox>
                            </graphic>
                            <VBox.margin><javafx.geometry.Insets left="0" right="0"/></VBox.margin>
                            <padding><javafx.geometry.Insets top="12" bottom="12" left="22" right="22"/></padding>
                        </Button>

                        <Button mnemonicParsing="false" styleClass="sidebar-menu-item" maxWidth="Infinity">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                   <Label text="Dépenses"/>
                                </HBox>
                            </graphic>
                            <VBox.margin><javafx.geometry.Insets left="0" right="0"/></VBox.margin>
                            <padding><javafx.geometry.Insets top="12" bottom="12" left="22" right="22"/></padding>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#showUsers" styleClass="sidebar-menu-item" maxWidth="Infinity">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                   <Label text="Budget"/>
                                </HBox>
                            </graphic>
                            <VBox.margin><javafx.geometry.Insets left="0" right="0"/></VBox.margin>
                            <padding><javafx.geometry.Insets top="12" bottom="12" left="22" right="22"/></padding>
                        </Button>

                        <Button mnemonicParsing="false" styleClass="sidebar-menu-item, sidebar-menu-item-active" maxWidth="Infinity">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                   <Label text="Utilisateurs"/>
                                </HBox>
                            </graphic>
                            <VBox.margin><javafx.geometry.Insets left="0" right="20.0"/></VBox.margin>
                            <padding><javafx.geometry.Insets top="12" bottom="12" left="22" right="22"/></padding>
                        </Button>

                        <Button mnemonicParsing="false" onAction="#showReclamations" styleClass="sidebar-menu-item" maxWidth="Infinity">
                            <graphic>
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                   <Label text="Réclamation"/>
                                </HBox>
                            </graphic>
                            <VBox.margin><javafx.geometry.Insets left="0" right="0"/></VBox.margin>
                            <padding><javafx.geometry.Insets top="12" bottom="12" left="22" right="22"/></padding>
                        </Button>

                    </children>
                </VBox>

                <!-- Divider -->
                <Separator styleClass="sidebar-divider-bottom">
                   <VBox.margin><javafx.geometry.Insets left="20.0" right="20.0" bottom="20.0"/></VBox.margin>
                </Separator>

                <!-- User Info & Logout -->
                <VBox styleClass="sidebar-user-container" spacing="15.0">
                   <padding><javafx.geometry.Insets bottom="30.0" left="22.0" right="22.0" top="10.0" /></padding>
                   <children>
                      <VBox spacing="2.0">
                         <children>
                            <Label styleClass="sidebar-user-label" text="Utilisateur" />
                            <Label fx:id="sidebarEmailLabel" styleClass="sidebar-user-email" text="admin@dinari.tn" />
                         </children>
                      </VBox>
                      <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-menu-item, logout-btn" maxWidth="Infinity">
                         <graphic>
                            <HBox spacing="12" alignment="CENTER_LEFT">
                               <Label text="⎋" styleClass="nav-icon" style="-fx-text-fill: #EF4444;"/>
                               <Label text="Déconnexion" style="-fx-text-fill: #EF4444;"/>
                            </HBox>
                         </graphic>
                         <padding><javafx.geometry.Insets top="8" bottom="8" left="0" right="0"/></padding>
                      </Button>
                   </children>
                </VBox>

            </children>
        </VBox>
    </left>

    <!-- ═══════════ MAIN CONTENT ═══════════ -->
    <center>
        <BorderPane>
            <!-- ── TOP HEADER BAR ── -->
            <top>
                <HBox alignment="CENTER_RIGHT" styleClass="content-header" spacing="20.0">
                    <children>
                        <!-- Search Box -->
                        <HBox styleClass="search-wrapper" alignment="CENTER_LEFT">
                            <children>
                                <Label text="🔍" style="-fx-font-size: 13px; -fx-text-fill: #9ca3af; -fx-padding: 0 6 0 12;"/>
                                <TextField promptText="Rechercher..." styleClass="search-field-inner" HBox.hgrow="ALWAYS"/>
                            </children>
                        </HBox>
                        
                        <!-- User Profile Chip -->
                        <HBox alignment="CENTER" spacing="10.0" styleClass="user-profile-chip">
                            <children>
                                <Label text="Welcome, Admin" styleClass="profile-name"/>
                                <Label styleClass="header-avatar" text="A" />
                            </children>
                        </HBox>
                    </children>
                    <padding><javafx.geometry.Insets bottom="15.0" left="30.0" right="30.0" top="15.0" /></padding>
                </HBox>
            </top>
            
            <!-- Dynamic View Container -->
            <center>
                <StackPane fx:id="contentArea" style="-fx-background-color: -fx-bg-color;">
                    <!-- Views will be loaded here -->
                </StackPane>
            </center>
        </BorderPane>
    </center>

</BorderPane>
