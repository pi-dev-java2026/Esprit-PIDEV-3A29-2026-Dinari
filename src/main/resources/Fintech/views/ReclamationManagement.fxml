<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" styleClass="dashboard-root" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/8.0.171" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Fintech.controllers.ReclamationManagementController">
   
   <!-- ═══════════ SIDEBAR ═══════════ -->
   <left>
      <VBox prefWidth="240.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <children>

            <!-- Logo -->
            <VBox styleClass="sidebar-logo-container">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Label styleClass="logo-text" text="DINARI" />
                     </children>
                  </HBox>
                  <Label styleClass="logo-subtitle" text="Gestion Financière" />
               </children>
               <padding><Insets bottom="20.0" left="22.0" right="22.0" top="28.0" /></padding>
            </VBox>

            <!-- Divider -->
            <Separator styleClass="sidebar-divider-top">
               <VBox.margin><Insets left="20.0" right="20.0" top="10.0" bottom="20.0"/></VBox.margin>
            </Separator>

            <!-- Menu Items -->
            <VBox spacing="4.0" VBox.vgrow="ALWAYS">
               <children>
                  <Button mnemonicParsing="false" onAction="#handleDashboard" styleClass="sidebar-menu-item" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="Abonnements"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

                  <Button mnemonicParsing="false" onAction="#handleTransactions" styleClass="sidebar-menu-item" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="Éducative"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

                  <Button mnemonicParsing="false" onAction="#handleBudgets" styleClass="sidebar-menu-item" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="Dépenses"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

                  <Button mnemonicParsing="false" onAction="#handleDashboard" styleClass="sidebar-menu-item" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="🏠  Tableau de bord"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

                  <Button mnemonicParsing="false" styleClass="sidebar-menu-item, sidebar-menu-item-active" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="📨  Réclamation"/>
                        </HBox>
                     </graphic>
                     <VBox.margin><Insets left="0" right="20.0"/></VBox.margin>
                     <padding><Insets top="12" bottom="12" left="22" right="22"/></padding>
                  </Button>

               </children>
            </VBox>

            <!-- Divider -->
            <Separator styleClass="sidebar-divider-bottom">
               <VBox.margin><Insets left="20.0" right="20.0" bottom="20.0"/></VBox.margin>
            </Separator>

            <!-- User Info & Logout -->
            <VBox styleClass="sidebar-user-container" spacing="15.0">
               <padding><Insets bottom="30.0" left="22.0" right="22.0" top="10.0" /></padding>
               <children>
                  <VBox spacing="2.0">
                     <children>
                        <Label styleClass="sidebar-user-label" text="Utilisateur" />
                        <Label fx:id="sidebarEmailLabel" styleClass="sidebar-user-email" text="admin@dinari.tn" />
                     </children>
                  </VBox>
                  <Button mnemonicParsing="false" onAction="#handleLogout" styleClass="sidebar-menu-item, logout-btn" maxWidth="Infinity">
                     <graphic>
                        <HBox spacing="12" alignment="CENTER_LEFT">
                           <Label text="⎋" styleClass="nav-icon" style="-fx-text-fill: #EF4444;"/>
                           <Label text="Déconnexion" style="-fx-text-fill: #EF4444;"/>
                        </HBox>
                     </graphic>
                     <padding><Insets top="8" bottom="8" left="0" right="0"/></padding>
                  </Button>
               </children>
            </VBox>

         </children>
      </VBox>
   </left>
   
   <!-- ═══════════ MAIN CONTENT ═══════════ -->
   <center>
      <VBox styleClass="main-content" BorderPane.alignment="CENTER">
         <children>

            <!-- ── TOP HEADER BAR ── -->
            <HBox alignment="CENTER_LEFT" styleClass="content-header">
               <children>

                  <!-- Title Block -->
                  <VBox HBox.hgrow="ALWAYS" spacing="3">
                     <children>
                        <Label styleClass="page-title" text="Gestion des Réclamations" />
                        <Label styleClass="page-subtitle" text="Visualisez et gérez l'ensemble des réclamations de la plateforme Dinari." />
                     </children>
                  </VBox>

                  <!-- Search Box -->
                  <HBox styleClass="search-wrapper" alignment="CENTER_LEFT">
                     <children>
                        <Label text="🔍" style="-fx-font-size: 13px; -fx-text-fill: #9ca3af; -fx-padding: 0 6 0 12;"/>
                        <TextField fx:id="searchField" onKeyReleased="#handleSearch"
                                   promptText="Rechercher une réclamation..."
                                   styleClass="search-field-inner" HBox.hgrow="ALWAYS"/>
                     </children>
                     <HBox.margin><Insets right="20.0"/></HBox.margin>
                  </HBox>

                  <!-- User Profile Chip -->
                  <HBox alignment="CENTER" spacing="10.0" styleClass="user-profile-chip">
                     <children>
                        <VBox alignment="CENTER_RIGHT" spacing="1">
                           <children>
                              <Label fx:id="profileNameLabel" styleClass="profile-name" text="" minWidth="-Infinity" />
                              <Label fx:id="profileRoleLabel" styleClass="profile-role" text="" minWidth="-Infinity" />
                           </children>
                        </VBox>
                        <Label fx:id="profileAvatarLabel" styleClass="header-avatar" text="?" />
                     </children>
                  </HBox>

               </children>
               <padding><Insets bottom="18.0" left="32.0" right="32.0" top="18.0" /></padding>
            </HBox>

            <!-- ── TOOLBAR: title + count + buttons ── -->
            <HBox alignment="CENTER_LEFT" styleClass="toolbar-section">
               <children>

                  <Label fx:id="totalReclamationsLabel" styleClass="section-title" text="Liste des Réclamations" />
                  <Label fx:id="reclamationCountLabel" styleClass="count-badge" text="0 Total">
                     <HBox.margin><Insets left="10.0"/></HBox.margin>
                  </Label>

                  <Region HBox.hgrow="ALWAYS" />

                  <!-- Chat Button (outline) -->
                  <Button mnemonicParsing="false" onAction="#handleChat" styleClass="btn-outline" text="💬  Chat IA" />
                  
                  <Region prefWidth="15.0" />

                  <!-- Add Button (primary) -->
                  <Button mnemonicParsing="false" onAction="#handleCreateReclamation" styleClass="btn-primary" text="+ Créer une réclamation" />
               </children>
               <padding><Insets bottom="14.0" left="32.0" right="32.0" top="14.0" /></padding>
            </HBox>

            <!-- ── RECLAMATIONS LIST ── -->
            <ListView fx:id="reclamationsList" styleClass="modern-users-list" VBox.vgrow="ALWAYS">
               <VBox.margin><Insets bottom="0.0" left="0.0" right="0.0" top="0.0" /></VBox.margin>
            </ListView>

         </children>
      </VBox>
   </center>
</BorderPane>
